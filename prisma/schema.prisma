generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum PlanInterval {
  MONTHLY
  YEARLY
  LIFETIME
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id            String   @id @default(uuid()) @map("_id")
  email         String   @unique
  passwordHash  String?
  name          String?
  phone         String?
  image         String?
  emailVerified DateTime?
  companyName     String?
  role            UserRole  @default(STAFF)
  isActive        Boolean   @default(true)
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  refreshTokens    RefreshToken[]
  workspaceRoles   WorkspaceMember[]
  subscriptions   Subscription[] @relation("UserSubscriptions")
  createdProjects Project[] @relation("ProjectCreator")
  assignedTasks   TaskAssignment[]
  approvedRevenues    Revenue[]
  approvedExpenses    Expense[]
  approvedDebitNotes  DebitNote[]   @relation("ApprovedDebitNotes")
  approvedCreditNotes CreditNote[]  @relation("ApprovedCreditNotes")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @map("_id")
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Account {
  id                String  @id @default(uuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(uuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id          String   @id @default(uuid()) @map("_id")
  name        String
  slug        String   @unique
  logo        String?
  description String?
  domain      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members         WorkspaceMember[]
  projects        Project[]
  crmLeads        CrmLead[]
  crmDeals        CrmDeal[]
  employees       Employee[]
  departments     Department[]
  invoices        Invoice[]
  expenses        Expense[]
  products        Product[]
  posOrders       PosOrder[]
  salesProposals  SalesProposal[]
  documents       Document[]
  assets          Asset[]
  assetAssignments AssetAssignment[]
  assetMaintenances AssetMaintenance[]
  assetDepreciations AssetDepreciation[]
  assetCategories AssetCategory[]
  assetBorrowRents      AssetBorrowRent[]
  assetBorrowRentPayments AssetBorrowRentPayment[]
  locations              Location[]
  calendarEvents  CalendarEvent[]
  reminders       Reminder[]
  workflows       Workflow[]
  mediaFiles      MediaFile[]
  activityLogs    ActivityLog[]
  customRoles     CustomRole[]
  productCategories ProductCategory[]
  taxes           Tax[]
  units           Unit[]
  leaveTypes          LeaveType[]
  leaveApplications   LeaveApplication[]
  attendances         Attendance[]
  shifts              Shift[]
  holidays            Holiday[]
  awards              Award[]
  promotions         Promotion[]
  resignations       Resignation[]
  terminations       Termination[]
  warnings           Warning[]
  complaints         Complaint[]
  transfers          Transfer[]
  acknowledgments    Acknowledgment[]
  events             Event[]
  companyPolicies    CompanyPolicy[]
  branches           Branch[]
  designations       Designation[]
  documentTypes      DocumentType[]
  awardTypes         AwardType[]
  terminationTypes   TerminationType[]
  warningTypes       WarningType[]
  complaintTypes     ComplaintType[]
  holidayTypes       HolidayType[]
  documentCategories DocumentCategory[]
  announcementCategories AnnouncementCategory[]
  eventTypes         EventType[]
  allowanceTypes     AllowanceType[]
  deductionTypes     DeductionType[]
  loanTypes          LoanType[]
  workingDays        WorkingDay[]
  ipRestricts        IpRestrict[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  bankTransfers       BankTransfer[]
  customerPayments    CustomerPayment[]
  vendorPayments      VendorPayment[]
  revenues            Revenue[]
  chartOfAccounts     ChartOfAccount[]
  contractors         Contractor[]
  workPermits         WorkPermit[]
  crmAccounts         CrmAccount[]
  crmContacts         CrmContact[]
  opportunities       Opportunity[]
  salesOrders         SalesOrder[]
  journalEntries      JournalEntry[]
  leaveBalances       LeaveBalance[]
  notifications       Notification[]
  payrollRuns         PayrollRun[]
  timesheets          Timesheet[]
  stockTransfers      StockTransfer[]
  warehouses          Warehouse[]
  vendors             Vendor[]
  purchaseInvoices    PurchaseInvoice[]
  purchaseReturns     PurchaseReturn[]
  customers           Customer[]
  salesInvoices       SalesInvoice[]
  salesReturns        SalesReturn[]
  quotations          Quotation[]
  salesQuotes         SalesQuote[]
  salesAccounts       SalesAccount[]
  posDiscounts        PosDiscount[]
  posReturns          PosReturn[]
  systemSetup         SystemSetup[]
  debitNotes          DebitNote[]
  creditNotes         CreditNote[]
  crmPipelines        CrmPipeline[]
  crmLeadStages       CrmLeadStage[]
  crmDealStages       CrmDealStage[]
  crmLabels           CrmLabel[]
  crmSources          CrmSource[]

  @@map("workspaces")
}

model WorkspaceMember {
  id           String   @id @default(uuid()) @map("_id")
  userId       String
  workspaceId  String
  role         UserRole @default(STAFF)
  customRoleId String?
  joinedAt     DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation("CustomRoleMembers", fields: [customRoleId], references: [id])

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model SubscriptionPlan {
  id          String        @id @default(uuid()) @map("_id")
  name        String
  description String?
  price       Float
  interval    PlanInterval  @default(MONTHLY)
  trialDays   Int           @default(0)
  isActive    Boolean       @default(true)
  features    String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id              String        @id @default(uuid()) @map("_id")
  userId          String
  planId          String
  status          PaymentStatus @default(PENDING)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user      User              @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model CrmLead {
  id           String     @id @default(uuid()) @map("_id")
  workspaceId  String
  title        String
  subject      String?
  company      String?
  email        String?
  phone        String?
  value        Float?
  followUpDate DateTime?
  status       LeadStatus @default(NEW)
  source       String?
  assignedTo   String?
  assignedToId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_leads")
}

model CrmDeal {
  id          String     @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  company     String?
  email       String?
  phone       String?
  value       Float?
  stage       String     @default("lead")
  probability Int        @default(0)
  source      String?
  assignedTo  String?
  notes       String?
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_deals")
}

model CrmPipeline {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_pipelines")
}

model CrmLeadStage {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  color       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_lead_stages")
}

model CrmDealStage {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  pipeline    String?
  probability Int      @default(0)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_deal_stages")
}

model CrmLabel {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  pipeline    String?
  color       String   @default("#6b7280")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_labels")
}

model CrmSource {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("crm_sources")
}

model Department {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employees Employee[]
  designations Designation[]

  @@map("departments")
}

model Employee {
  id                 String    @id @default(uuid()) @map("_id")
  workspaceId        String
  userId             String?
  departmentId       String?
  employeeId         String
  firstName          String
  lastName           String
  email              String
  phone              String?
  position           String?
  salary             Float?
  hireDate           DateTime  @default(now())
  dateOfBirth        DateTime?
  gender             String?
  biometricEmployeeId String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  country            String?
  bankName           String?
  bankAccountNumber  String?
  bankRoutingNumber  String?
  hourlyRate         Float?
  overtimeRate       Float?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  department         Department?         @relation(fields: [departmentId], references: [id])
  leaveApplications  LeaveApplication[]
  leaveBalances      LeaveBalance[]
  attendanceRecords  Attendance[]
  payslips           Payslip[]
  documents          Document[]
  awards             Award[]
  promotions         Promotion[]
  resignations       Resignation[]
  terminations       Termination[]
  warnings           Warning[]
  complaints         Complaint[]
  complaintsAgainst  Complaint[]  @relation("ComplaintAgainst")
  transfers          Transfer[]
  acknowledgments    Acknowledgment[]
  events             Event[]

  @@map("employees")
}

model Invoice {
  id           String        @id @default(uuid()) @map("_id")
  workspaceId  String
  number       String
  customerName String
  customerEmail String?
  items        Json
  subtotal     Float
  tax          Float         @default(0)
  total        Float
  status       InvoiceStatus @default(DRAFT)
  dueDate      DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Expense {
  id               String   @id @default(uuid()) @map("_id")
  workspaceId      String
  expenseNumber    String?
  category         String
  bankAccountId    String?
  chartOfAccountId String?
  amount           Float
  referenceNumber  String?
  description      String?
  date             DateTime
  status           String   @default("Draft")
  approvedById     String?
  receipt          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount?   @relation(fields: [bankAccountId], references: [id])
  chartOfAccount ChartOfAccount? @relation(fields: [chartOfAccountId], references: [id])
  approvedBy     User?          @relation(fields: [approvedById], references: [id])

  @@map("expenses")
}

model Project {
  id          String        @id @default(uuid()) @map("_id")
  workspaceId String
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User             @relation("ProjectCreator", fields: [createdBy], references: [id])
  tasks     ProjectTask[]
  members   ProjectMember[]

  @@map("projects")
}

model ProjectTask {
  id              String     @id @default(uuid()) @map("_id")
  projectId       String
  title           String
  description     String?
  status          TaskStatus @default(TODO)
  priority        String     @default("medium")
  assignedTo      String?
  dueDate         DateTime?
  estimatedHours  Float?
  actualHours     Float?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignments TaskAssignment[]

  @@map("project_tasks")
}

model TaskAssignment {
  id     String @id @default(uuid()) @map("_id")
  taskId String
  userId String

  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignments")
}

model ProjectMember {
  id        String   @id @default(uuid()) @map("_id")
  projectId String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Product {
  id                String   @id @default(uuid()) @map("_id")
  workspaceId       String
  name              String
  sku               String?
  description       String?
  shortDescription  String?
  itemType          String   @default("Product")
  productType       String?
  warrantyInfo      String?
  price             Float
  cost              Float?
  stock             Int      @default(0)
  category          String?
  categoryId        String?
  taxId             String?
  taxRate           Float    @default(0)
  image             String?
  additionalImages  Json     @default("[]")
  warehouseId       String?
  unitId            String?
  reorderLevel      Int?
  maxLevel          Int?
  valuationMethod   String   @default("Weighted Average")
  trackInventory    Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orderItems       PosOrderItem[]
  productCategory  ProductCategory? @relation(fields: [categoryId], references: [id])
  tax              Tax?             @relation(fields: [taxId], references: [id])
  stockTransfers   StockTransfer[]
  warehouse        Warehouse?       @relation(fields: [warehouseId], references: [id])
  unit             Unit?            @relation(fields: [unitId], references: [id])

  @@map("products")
}

model PosOrder {
  id           String        @id @default(uuid()) @map("_id")
  workspaceId  String
  orderNumber  String        @unique
  customerName String?
  customerId   String?
  warehouseId  String?
  items        Json
  subtotal     Float
  tax          Float         @default(0)
  total        Float
  status       PaymentStatus @default(PENDING)
  createdAt    DateTime      @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orderItems PosOrderItem[]
  warehouse  Warehouse?    @relation(fields: [warehouseId], references: [id])
  posReturns PosReturn[]

  @@map("pos_orders")
}

model PosOrderItem {
  id        String @id @default(uuid()) @map("_id")
  orderId   String
  productId String
  quantity  Int
  price     Float
  total     Float

  order   PosOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id])

  @@map("pos_order_items")
}

model PosDiscount {
  id              String    @id @default(uuid()) @map("_id")
  workspaceId     String
  name            String
  applyOn         String    @default("Product")
  discountType    String    @default("PERCENTAGE")
  value           Float     @default(0)
  minimumQuantity Int       @default(1)
  startDate       DateTime?
  endDate         DateTime?
  productIds      Json      @default("[]")
  selectedCategory String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("pos_discounts")
}

model PosReturn {
  id            String   @id @default(uuid()) @map("_id")
  workspaceId   String
  returnNumber  String   @unique
  orderId       String?
  customerName  String?
  warehouseId   String?
  warehouseName String?
  returnDate    DateTime
  reason        String?
  notes         String?
  items         Json     @default("[]")
  totalAmount   Float    @default(0)
  status        String   @default("Draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  order     PosOrder?  @relation(fields: [orderId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])

  @@map("pos_returns")
}

model SalesProposal {
  id                   String   @id @default(uuid()) @map("_id")
  workspaceId          String
  number               String   @unique
  customerName         String
  customerEmail        String?
  warehouse            String?
  paymentTerms         String?
  notes                String?
  specialInstructions  String?
  items                Json
  subtotal             Float
  discount             Float    @default(0)
  tax                  Float    @default(0)
  total                Float
  balance              Float
  status               String   @default("Draft")
  proposalDate         DateTime
  dueDate              DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("sales_proposals")
}

model Quotation {
  id            String   @id @default(uuid()) @map("_id")
  workspaceId   String
  number        String   @unique
  customerName  String
  customerEmail String?
  warehouse     String?
  paymentTerms  String?
  notes         String?
  items         Json     @default("[]")
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  status        String   @default("Draft")
  proposalDate  DateTime
  dueDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("quotations")
}

model Setting {
  id        String   @id @default(uuid()) @map("_id")
  key       String   @unique
  value     String   @default("")
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model LoginLog {
  id        String   @id @default(uuid()) @map("_id")
  userId    String?
  email     String
  role      String?
  ip        String?
  userAgent String?
  status    String   @default("SUCCESS")
  createdAt DateTime @default(now())

  @@map("login_logs")
}

model HelpdeskCategory {
  id          String   @id @default(uuid()) @map("_id")
  name        String
  description String?
  color       String   @default("#6366f1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("helpdesk_categories")
}

model HelpdeskTicket {
  id          String   @id @default(uuid()) @map("_id")
  ticketId    String   @unique
  title       String
  description String?
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  categoryId  String?
  creatorName String
  creatorEmail String?
  replies     Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("helpdesk_tickets")
}

model Coupon {
  id           String    @id @default(uuid()) @map("_id")
  name         String
  code         String    @unique
  type         String    @default("PERCENTAGE")
  discount     Float
  usageLimit   Int?
  limitPerUser Int?
  minSpend     Float?
  maxSpend     Float?
  description  String?
  expiryDate   DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("coupons")
}

model Addon {
  id          String   @id @default(uuid()) @map("_id")
  name        String
  slug        String   @unique
  description String?
  version     String   @default("1.0.0")
  isActive    Boolean  @default(true)
  isPremium   Boolean  @default(false)
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions AddonSubscription[]

  @@map("addons")
}

model AddonSubscription {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  addonId     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  addon Addon @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, addonId])
  @@map("addon_subscriptions")
}

model Document {
  id              String    @id @default(uuid()) @map("_id")
  workspaceId     String
  employeeId      String?
  name            String
  title           String?
  description     String?
  fileUrl         String?
  fileType        String?
  fileSize        Int?
  folder          String    @default("general")
  tags            String[]
  documentCategory String?
  effectiveDate   DateTime?
  approvedBy      String?
  uploadedBy      String?
  status          String    @default("Pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employee  Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Location {
  id             String   @id @default(uuid()) @map("_id")
  workspaceId    String
  name           String
  code           String
  type           String
  parentLocation String?
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
