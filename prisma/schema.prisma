  warehouse   Warehouse?   @relation(fields: [warehouseId], references: [id])
  debitNotes  DebitNote[]

  @@map("purchase_returns")
}

// ─── Accounting: Debit Note ──────────────────────────────────────────────────

model DebitNote {
