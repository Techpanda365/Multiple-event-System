  children     ChartOfAccount[]     @relation("ChartOfAccountHierarchy")
  journalLines JournalEntryLine[]
  revenues     Revenue[]
  expenses     Expense[]

  @@map("chart_of_accounts")
}

model JournalEntry {
  id           String    @id @default(uuid()) @map("_id")
  workspaceId  String
