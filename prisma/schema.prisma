}







model BankTransaction {
  id            String   @id @default(uuid()) @map("_id")
  bankAccountId String
  workspaceId   String
  date          DateTime
  description   String
  reference     String?
  amount        Float
  type          String   @default("DEBIT")
  category      String?
  status        String   @default("Completed")
