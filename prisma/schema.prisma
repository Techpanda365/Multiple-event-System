  reference      String?
  description    String?
  status         String   @default("Pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromAccount  BankAccount @relation("fromTransfers", fields: [fromAccountId], references: [id])
  toAccount    BankAccount @relation("toTransfers", fields: [toAccountId], references: [id])

  @@map("bank_transfers")
}

model Revenue {
