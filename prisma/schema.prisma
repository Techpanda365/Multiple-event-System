  salesReturns    SalesReturn[]
  customerPayments CustomerPayment[]
  creditNotes     CreditNote[]

  @@map("customers")
}

// ─── Sales: Invoice ──────────────────────────────────────────────────────────

model SalesInvoice {
  id                   String   @id @default(uuid()) @map("_id")
  workspaceId          String
  invoiceNumber        String   @unique
  customerId           String?
  customerName         String
  invoiceDate          DateTime
  dueDate              DateTime?
  warehouseId          String?
  warehouseName        String?
  paymentTerms         String?
  notes                String?
  items                Json     @default("[]")
  subtotal             Float    @default(0)
  discount             Float    @default(0)
  tax                  Float    @default(0)
  total                Float    @default(0)
  balance              Float    @default(0)
  status               String   @default("Draft")
  signature            String?  // base64 data URL of the signature image
  generatedAt          DateTime?
  pdfUrl               String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id])

  @@map("sales_invoices")
}

// ─── Sales: Return ───────────────────────────────────────────────────────────

model SalesReturn {
  id            String   @id @default(uuid()) @map("_id")
  workspaceId   String
  returnNumber  String   @unique
  customerId    String?
  customerName  String
  warehouseId   String?
  warehouseName String?
  invoiceId     String?
  returnDate    DateTime
  reason        String?
  notes         String?
  items         Json     @default("[]")
  totalAmount   Float    @default(0)
  status        String   @default("Draft")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id])
  creditNotes  CreditNote[]

  @@map("sales_returns")
}

// ─── Sales: System Setup ─────────────────────────────────────────────────────

model SystemSetup {
  id          String   @id @default(uuid()) @map("_id")
  workspaceId String
  type        String   // accountType, accountIndustry, opportunityStage, shippingProvider, caseType, documentType, documentFolder
  name        String
  attributes  Json     @default("{}") // { order: 1, color: "#3b82f6", website: "...", description: "..." }
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type, name])
  @@map("system_setup")
}
